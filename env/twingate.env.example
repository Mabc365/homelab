# Environment variables for Twingate Connector

# Your Twingate network (e.g. yourcompany.twingate.com)
TWINGATE_NETWORK=

# Connector tokens issued in the Twingate admin console
TWINGATE_ACCESS_TOKEN=
TWINGATE_REFRESH_TOKEN=

# Optional: label this connector with the host's name in the admin console
TWINGATE_LABEL_HOSTNAME=
